# Firebase client SDK config (safe to expose to the browser)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Set to "true" for local dev against the Firebase Emulator Suite.
# Leave unset/false in production.
NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true

# Firebase Admin SDK (server-only secrets, never prefix with NEXT_PUBLIC_)
# Not required when NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Required alongside NEXT_PUBLIC_USE_FIREBASE_EMULATORS=true so the Admin SDK
# talks to the local emulators instead of real Google Cloud.
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099

# Protects /api/cron/expire-sessions. Set this in Vercel's project env vars —
# Vercel then automatically sends it as a Bearer token on cron-triggered
# requests (see vercel.json). Optional locally; the route allows unauthenticated
# calls only when this is unset, which is fine for local testing.
CRON_SECRET=
