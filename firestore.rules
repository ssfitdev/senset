rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwnSession(sessionId) {
      return request.auth != null && request.auth.uid == sessionId;
    }

    // Preloaded roster. Writes only ever go through the Admin SDK (login
    // lookup, CSV upload), which bypasses these rules entirely. Admins can
    // read directly so the admin panel can stream the roster live instead
    // of polling a Route Handler; regular students can never read this.
    match /students/{studentId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Question bank, including correct answers. Students never reach this —
    // their exam paper is served as a denormalized copy without
    // correctOption under examSessions/{id}/sessionQuestions. Admins can
    // read directly (they're the ones who set the correct answers) so the
    // admin panel can stream the bank live; writes stay Admin-SDK-only.
    match /questions/{questionId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Exam window/duration/toggles. Students need to read this directly to
    // render live countdown/window state; only admins can change it.
    match /examConfig/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /examSessions/{sessionId} {
      allow read: if isOwnSession(sessionId) || isAdmin();

      // Sessions are only ever created/graded by the Admin SDK
      // (/api/exam/start, /api/exam/submit), never directly by the client.
      allow create, delete: if false;

      // Students may only update their own "which question am I looking at"
      // bookmark, and only while the session is still active and unexpired.
      // Every other field (status, score, totals, ...) is Admin-SDK-only.
      allow update: if isOwnSession(sessionId)
        && resource.data.status == 'in_progress'
        && request.time < resource.data.expiresAt
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['lastViewedOrder']);

      match /sessionQuestions/{order} {
        allow read: if isOwnSession(sessionId) || isAdmin();
        allow write: if false;
      }

      match /answers/{sessionQuestionId} {
        allow read: if isOwnSession(sessionId) || isAdmin();

        allow create, update: if isOwnSession(sessionId)
          && get(/databases/$(database)/documents/examSessions/$(sessionId)).data.status == 'in_progress'
          && request.time < get(/databases/$(database)/documents/examSessions/$(sessionId)).data.expiresAt
          && request.resource.data.selectedOption in ['A', 'B', 'C', 'D'];

        allow delete: if false;
      }

      match /events/{eventId} {
        allow read: if isAdmin() || isOwnSession(sessionId);
        allow create: if isOwnSession(sessionId);
        allow update, delete: if false;
      }
    }

    // Free-form student feedback/suggestions. Students can only create their
    // own (studentId must match their uid) and can never read back — this is
    // a one-way mailbox to the admin, not a public or editable log.
    match /feedback/{feedbackId} {
      allow read: if isAdmin();
      allow create: if request.auth != null
        && request.resource.data.studentId == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() > 0
        && request.resource.data.message.size() <= 2000;
      allow update, delete: if false;
    }
  }
}
